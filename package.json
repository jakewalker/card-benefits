{
  "name": "card-benefits",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "deploy": "npm run build && wrangler deploy -c dist/card_benefits/wrangler.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "hono": "^4.7.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.5.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.10.0",
    "@cloudflare/workers-types": "^4.20250620.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.2.0",
    "wrangler": "^4.20.0"
  }
}
